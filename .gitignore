# =============================================================================
# Dados — nunca versionar datasets brutos ou processados
# =============================================================================
data/raw/*
data/processed/*
data/interim/*
data/external/*

# Manter a estrutura de pastas
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/interim/.gitkeep
!data/external/.gitkeep

# Formatos de dados comuns
*.csv
*.tsv
*.parquet
*.feather
*.arrow
*.h5
*.hdf5
*.pkl
*.pickle
*.db
*.sqlite
*.sqlite3
